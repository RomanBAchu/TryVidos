@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-viewport spidey-theme">
    @* ХЕДЕР *@
    <div class="hud-header d-flex justify-content-between p-2">
        <div class="hud-title">FNSM // NET_NODE</div>
        <div class="hud-status">● CONNECTED</div>
    </div>

    @* ЧАТ (ЗАНИМАЕТ ВСЁ СВОБОДНОЕ МЕСТО) *@
    <div id="msgList" class="messages-list">
        @foreach (var msg in messages) { 
            <div class="msg-bubble @(msg.User == "Система" ? "sys-msg" : "")">
                <span class="msg-user">@msg.User.ToUpper()</span>
                <p class="msg-text">@msg.Text</p>
            </div> 
        }
    </div>

    @* ВИДЕО-БЛОК (АДАПТИВНАЯ СЕТКА) *@
    <div class="video-container-fluid @(_inCall ? "v-active" : "v-idle")">
        <div class="video-grid-mesh">
            <div class="video-item local">
                <video id="localVideo" autoplay muted playsinline></video>
                <div class="v-tag">YOU</div>
            </div>
            <div id="remoteVideos" class="remote-mesh">
                @* Сюда JS будет вставлять видео других участников *@
            </div>
        </div>
    </div>

    @* ПАНЕЛЬ УПРАВЛЕНИЯ *@
    <div class="bottom-controls">
        <div class="call-row px-3 pt-2">
            @if (!_inCall) {
                <button class="btn-spidey-action w-100" @onclick="JoinCall">📞 GO LIVE</button>
            } else {
                <button class="btn-spidey-hangup w-100" @onclick="LeaveCall">🚫 DISCONNECT</button>
            }
        </div>
        <div class="input-row d-flex gap-2 p-3">
            <input @bind="userName" class="spidey-input name-field" placeholder="ID" />
            <input @bind="newMessage" @onkeyup="HandleKeyPress" class="spidey-input msg-field" placeholder="TYPE_MESSAGE..." />
            <button class="btn-spidey-send" @onclick="Send">►</button>
        </div>
    </div>
</div>

<style>
    :root {
        --spidey-red: #e62429;
        --spidey-blue: #0096FF;
        --glow: 0 0 15px rgba(230, 36, 41, 0.5);
    }

    /* ОСНОВНОЙ КОНТЕЙНЕР НА ВЕСЬ ЭКРАН */
    .chat-viewport {
        display: flex;
        flex-direction: column;
        height: 100dvh; /* Динамический вьюпорт для мобил */
        background: radial-gradient(circle at center, #1a1a2e 0%, #050505 100%);
        color: white;
        overflow: hidden;
    }

    /* ЧАТ С АВТО-РАСШИРЕНИЕМ */
    .messages-list {
        flex: 1; /* Занимает всё свободное место */
        overflow-y: auto;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .msg-bubble {
        background: rgba(255, 255, 255, 0.07);
        border-left: 3px solid var(--spidey-red);
        padding: 8px 12px;
        border-radius: 0 15px 15px 0;
        width: fit-content;
        max-width: 85%;
        backdrop-filter: blur(5px);
    }
    .msg-user { color: var(--spidey-red); font-size: 0.7rem; font-weight: bold; }
    .msg-text { margin: 0; font-size: 0.9rem; }
    .sys-msg { border-left-color: var(--spidey-blue); opacity: 0.7; }

    /* ВИДЕО-БЛОК (MESH GRID) */
    .video-container-fluid {
        background: rgba(0,0,0,0.6);
        border-top: 1px solid var(--spidey-red);
        transition: all 0.3s ease;
    }
    .v-idle { height: 0; opacity: 0; padding: 0; overflow: hidden; }
    .v-active { min-height: 120px; padding: 10px; opacity: 1; }

    .video-grid-mesh {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .video-item video {
        width: 80px; height: 80px; border-radius: 50%;
        border: 2px solid var(--spidey-red); box-shadow: var(--glow);
        object-fit: cover;
    }
    .local { position: relative; }
    .v-tag { position: absolute; bottom: -5px; left: 50%; transform: translateX(-50%); background: var(--spidey-red); font-size: 0.6rem; padding: 2px 6px; border-radius: 10px; }

    /* СЕТКА ДЛЯ ОСТАЛЬНЫХ */
    .remote-mesh { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
    /* Стиль для видео, которые добавляет JS */
    .remote-v { width: 90px; height: 90px; border-radius: 12px; border: 1px solid var(--spidey-blue); object-fit: cover; background: #000; }

    /* УПРАВЛЕНИЕ */
    .bottom-controls { background: #000; padding-bottom: env(safe-area-inset-bottom); }
    .btn-spidey-action { background: var(--spidey-red); border: none; color: white; padding: 12px; border-radius: 25px; font-weight: bold; box-shadow: var(--glow); }
    .btn-spidey-hangup { background: transparent; border: 2px solid var(--spidey-red); color: white; padding: 10px; border-radius: 25px; }

    .spidey-input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 10px; padding: 10px; }
    .name-field { width: 70px; text-align: center; color: var(--spidey-red); font-weight: bold; }
    .msg-field { flex: 1; }
    .btn-spidey-send { background: var(--spidey-blue); border: none; color: white; width: 45px; border-radius: 10px; font-size: 1.2rem; }

    .hud-header { background: rgba(230, 36, 41, 0.2); border-bottom: 1px solid var(--spidey-red); font-size: 0.7rem; letter-spacing: 2px; }
</style>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";
    private bool _inCall = false;

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/chathub")).WithAutomaticReconnect().Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => InvokeAsync(async () => {
            messages.Add(new Message { User = u, Text = t });
            if (u != userName && u != "Система") {
                await JS.InvokeVoidAsync("spideyVibrate", new int[] { 100, 50, 100 });
            }
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToEnd", "msgList");
        }));

        hub.On<List<string>>("UserList", async (users) => {
            if (_inCall && hub != null) {
                foreach (var id in users) {
                    var offer = await JS.InvokeAsync<string?>("createOfferGroup", id);
                    if (offer != null) await hub.SendAsync("SendSignal", offer, id);
                }
            }
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            await InvokeAsync(async () => {
                if (hub == null) return;
                try {
                    if (signal == "requestList" && _inCall) {
                        var offer = await JS.InvokeAsync<string?>("createOfferGroup", senderId);
                        if (offer != null) await hub.SendAsync("SendSignal", offer, senderId);
                    }
                    else if (signal.Contains("candidate")) await JS.InvokeVoidAsync("addIceCandidateGroup", signal, senderId);
                    else if (signal.Contains("offer")) {
                        var answer = await JS.InvokeAsync<string?>("processOfferGroup", signal, senderId);
                        if (answer != null) await hub.SendAsync("SendSignal", answer, senderId);
                    }
                    else if (signal.Contains("answer")) await JS.InvokeVoidAsync("processAnswerGroup", signal, senderId);
                } catch { }
            });
        });

        hub.On<string>("UserLeft", id => JS.InvokeVoidAsync("removeUser", id));

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task JoinCall() {
        var ok = await JS.InvokeAsync<bool>("startLocalVideo", "localVideo");
        if (ok && hub != null) {
            _inCall = true;
            await JS.InvokeVoidAsync("spideyVibrate", new int[] { 50, 30, 50 });
            await hub.SendAsync("SendMessage", "Система", userName + " В СЕТИ");
            await hub.SendAsync("SendSignal", "requestList", "all");
        }
    }

    private async Task LeaveCall() {
        _inCall = false;
        await JS.InvokeVoidAsync("hangup");
        if (hub != null) await hub.SendAsync("SendMessage", "Система", userName + " ВЫШЕЛ");
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    [JSInvokable] public async Task SendSignalJS(string s, string t) { if (hub != null) await hub.SendAsync("SendSignal", s, t); }
    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    public async ValueTask DisposeAsync() { if (hub != null) await hub.DisposeAsync(); }
    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
