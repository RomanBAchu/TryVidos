@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="spidey-viewport">
    @* ВЕРХНИЙ HUD (ВИДЕО) *@
    <div class="video-hub @(_inCall ? "expanded" : "collapsed")">
        <div class="hud-scanner"></div>
        <div class="video-mesh">
            <div class="v-slot local">
                <video id="localVideo" autoplay muted playsinline></video>
                <div class="v-badge">YOU</div>
            </div>
            <div id="remoteVideos" class="remote-mesh-container">
                @* Сюда JS вставляет крупные плитки *@
            </div>
        </div>
        @if (_inCall) {
            <div class="v-footer">● FNSM_SECURE_LINK // ACTIVE</div>
        }
    </div>

    @* СРЕДНИЙ БЛОК (ЧАТ) *@
    <div id="msgList" class="spidey-chat-area">
        @foreach (var msg in messages) { 
            <div class="spidey-msg @(msg.User == "Система" ? "sys" : "")">
                <span class="u">@msg.User.ToUpper()</span>
                <span class="t">@msg.Text</span>
            </div> 
        }
    </div>

    @* НИЖНИЙ БЛОК (УПРАВЛЕНИЕ) *@
    <div class="spidey-nav">
        <div class="input-container d-flex gap-2">
            <input @bind="userName" class="s-input id-field" />
            <input @bind="newMessage" @onkeyup="HandleKeyPress" class="s-input text-field" placeholder="DATA_INPUT..." />
            <button class="s-btn-send" @onclick="Send">►</button>
        </div>
        <div class="call-action mt-2">
            @if (!_inCall) {
                <button class="s-btn-call" @onclick="JoinCall">📞 СТАРТ ТРАНСЛЯЦИИ</button>
            } else {
                <button class="s-btn-hangup" @onclick="LeaveCall">🚫 ОБОРВАТЬ СВЯЗЬ</button>
            }
        </div>
    </div>
</div>

<style>
    :root { --red: #e62429; --blue: #0096FF; --glow: 0 0 15px rgba(230,36,41,0.5); }
    
    .spidey-viewport { 
        display: flex; flex-direction: column; height: 100dvh; 
        background: #000; color: #fff; font-family: 'Segoe UI', sans-serif; overflow: hidden;
    }

    /* ВИДЕО - ТЕПЕРЬ ГЛАВНОЕ */
    .video-hub { 
        background: radial-gradient(circle, #222 0%, #000 100%);
        border-bottom: 2px solid var(--red);
        transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative; overflow: hidden;
    }
    .collapsed { height: 60px; }
    .expanded { height: 55%; } /* Занимает больше половины экрана */

    .video-mesh { 
        display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); 
        gap: 10px; padding: 15px; height: 100%; align-content: center;
    }

    .v-slot video { 
        width: 100%; height: 100%; max-height: 180px; object-fit: cover;
        border: 1px solid var(--red); border-radius: 12px; box-shadow: var(--glow);
    }
    .local { position: relative; max-width: 160px; margin: 0 auto; }
    .v-badge { position: absolute; top: 10px; left: 10px; background: var(--red); font-size: 0.6rem; padding: 2px 6px; border-radius: 4px; font-weight: bold; }

    /* ЧАТ - ТЕПЕРЬ ПОД ВИДЕО */
    .spidey-chat-area { 
        flex: 1; overflow-y: auto; padding: 15px; 
        background: rgba(255,255,255,0.03); display: flex; flex-direction: column; gap: 8px;
    }
    .spidey-msg { background: rgba(255,255,255,0.05); padding: 8px; border-radius: 4px; border-left: 2px solid var(--red); }
    .spidey-msg .u { color: var(--red); font-size: 0.65rem; font-weight: bold; display: block; }
    .spidey-msg .t { font-size: 0.85rem; }
    .sys { border-left-color: var(--blue); opacity: 0.6; }

    /* УПРАВЛЕНИЕ - ВСЕГДА ВНИЗУ */
    .spidey-nav { background: #111; padding: 15px; border-top: 1px solid #333; padding-bottom: calc(15px + env(safe-area-inset-bottom)); }
    .s-input { background: #222; border: 1px solid #444; color: #fff; border-radius: 8px; padding: 10px; font-size: 0.9rem; }
    .id-field { width: 70px; text-align: center; color: var(--red); font-weight: bold; }
    .text-field { flex: 1; }
    .s-btn-send { background: var(--blue); border: none; color: #fff; width: 50px; border-radius: 8px; }
    
    .s-btn-call { background: var(--red); border: none; color: #fff; width: 100%; padding: 12px; border-radius: 25px; font-weight: bold; box-shadow: var(--glow); margin-top: 5px; }
    .s-btn-hangup { background: transparent; border: 2px solid var(--red); color: #fff; width: 100%; padding: 10px; border-radius: 25px; margin-top: 5px; }

    .hud-scanner { position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: rgba(255,255,255,0.1); animation: scan 3s infinite linear; }
    @@keyframes scan { 0% { top: 0; } 100% { top: 100%; } }
</style>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";
    private bool _inCall = false;

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/chathub")).WithAutomaticReconnect().Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => InvokeAsync(async () => {
            messages.Add(new Message { User = u, Text = t });
            if (u != userName && u != "Система") {
                await JS.InvokeVoidAsync("spideyVibrate", new int[] { 100, 50, 100 });
            }
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToEnd", "msgList");
        }));

        hub.On<List<string>>("UserList", async (users) => {
            if (_inCall && hub != null) {
                foreach (var id in users) {
                    var offer = await JS.InvokeAsync<string?>("createOfferGroup", id);
                    if (offer != null) await hub.SendAsync("SendSignal", offer, id);
                }
            }
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            await InvokeAsync(async () => {
                if (hub == null) return;
                try {
                    if (signal == "requestList" && _inCall) {
                        var offer = await JS.InvokeAsync<string?>("createOfferGroup", senderId);
                        if (offer != null) await hub.SendAsync("SendSignal", offer, senderId);
                    }
                    else if (signal.Contains("candidate")) await JS.InvokeVoidAsync("addIceCandidateGroup", signal, senderId);
                    else if (signal.Contains("offer")) {
                        var answer = await JS.InvokeAsync<string?>("processOfferGroup", signal, senderId);
                        if (answer != null) await hub.SendAsync("SendSignal", answer, senderId);
                    }
                    else if (signal.Contains("answer")) await JS.InvokeVoidAsync("processAnswerGroup", signal, senderId);
                } catch { }
            });
        });

        hub.On<string>("UserLeft", id => JS.InvokeVoidAsync("removeUser", id));

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task JoinCall() {
        var ok = await JS.InvokeAsync<bool>("startLocalVideo", "localVideo");
        if (ok && hub != null) {
            _inCall = true;
            await JS.InvokeVoidAsync("spideyVibrate", new int[] { 50, 30, 50 });
            await hub.SendAsync("SendMessage", "Система", userName + " В ЭФИРЕ");
            await hub.SendAsync("SendSignal", "requestList", "all");
        }
    }

    private async Task LeaveCall() {
        _inCall = false;
        await JS.InvokeVoidAsync("hangup");
        if (hub != null) await hub.SendAsync("SendMessage", "Система", userName + " ВЫШЕЛ");
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    [JSInvokable] public async Task SendSignalJS(string s, string t) { if (hub != null) await hub.SendAsync("SendSignal", s, t); }
    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    public async ValueTask DisposeAsync() { if (hub != null) await hub.DisposeAsync(); }
    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
