@page "/chat"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-container">
    <div class="messages-list" style="height: 250px; overflow-y: auto; background: #eee; padding: 10px;">
        @foreach (var msg in messages) { <div><b>@msg.User:</b> @msg.Text</div> }
    </div>

    <div class="video-section d-flex justify-content-around p-2">
        <video id="localVideo" autoplay muted playsinline style="width:140px; background:black;"></video>
        <video id="remoteVideo" autoplay playsinline style="width:140px; background:black;"></video>
    </div>

    <div class="p-2 text-center">
        <button class="btn btn-success" @onclick="StartCall">📞 Видео-эфир</button>
    </div>

    <div class="input-group p-2">
        <input @bind="userName" class="form-control w-25" placeholder="Имя" />
        <input @bind="newMessage" @onkeyup="HandleKeyPress" class="form-control w-50" placeholder="Текст..." />
        <button class="btn btn-primary" @onclick="Send">OK</button>
    </div>
</div>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Гость", newMessage = "";

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/chathub")).Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => {
            messages.Add(new Message { User = u, Text = t });
            InvokeAsync(StateHasChanged);
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            if (signal.Contains("candidate")) await JS.InvokeVoidAsync("addIceCandidate", signal);
            else if (signal.Contains("offer")) {
                var answer = await JS.InvokeAsync<string>("processOffer", signal);
                await hub.SendAsync("SendSignal", answer, senderId);
            }
            else if (signal.Contains("answer")) await JS.InvokeVoidAsync("processAnswer", signal);
        });

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task StartCall() {
        await JS.InvokeVoidAsync("startLocalVideo", "localVideo");
        var offer = await JS.InvokeAsync<string>("createOffer");
        if (hub != null) await hub.SendAsync("SendSignal", offer, "all");
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    [JSInvokable]
    public async Task SendIceCandidate(string candidate) {
        if (hub != null) await hub.SendAsync("SendSignal", candidate, "all");
    }

    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    public async ValueTask DisposeAsync() { if (hub != null) await hub.DisposeAsync(); }
    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
