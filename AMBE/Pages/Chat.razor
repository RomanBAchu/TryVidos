@namespace AMBE.Components
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="spidey-viewport">
    @* ВЕРХНИЙ HUD (ВИДЕО) *@
    <div class="video-hub @(_inCall ? "expanded" : "collapsed")">
        <div class="hud-scanner"></div>
        
        <div class="v-slot local" style="display: @(_inCall ? "block" : "none")">
            <video id="localVideo" autoplay muted playsinline></video>
            <div class="v-badge">Ты</div>
            <button class="cam-toggle-btn @(_isCamOn ? "" : "off")" @onclick="ToggleCam">
                @(_isCamOn ? "Камера" : "ВЫКЛ")
            </button>
        </div>

        <div id="remoteVideos" class="remote-mesh-container"></div>

        @if (_inCall) {
            <div class="v-footer">● ЗАЩИЩЕННЫЙ_КАНАЛ_FNSM // АКТИВЕН</div>
        }
    </div>

    @* СРЕДНИЙ БЛОК (ЧАТ) *@
    <div id="msgList" class="spidey-chat-area">
        @foreach (var msg in messages) { 
            <div class="spidey-msg @(msg.User == "Система" ? "sys" : "")">
                <span class="u">@msg.User.ToUpper()</span>
                <span class="t">@msg.Text</span>
            </div> 
        }
    </div>

    @* НИЖНИЙ БЛОК (УПРАВЛЕНИЕ) - ОБНОВЛЕН ПОД МОБИЛКИ *@
    <div class="spidey-nav">
        <div class="mobile-input-stack">
            <div class="fields-group">
                <input @bind="userName" class="s-input id-field" placeholder="Позывной..." />
                <input @bind="newMessage" @onkeyup="HandleKeyPress" class="s-input text-field" placeholder="Сообщение..." />
            </div>
            <button class="s-btn-send-round" @onclick="Send">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                    <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                </svg>
            </button>
        </div>
        <div class="call-action mt-2">
            @if (!_inCall) {
                <button class="s-btn-call" @onclick="JoinCall">📞 ВИДЕО ЗВОНОК</button>
            } else {
                <button class="s-btn-hangup" @onclick="LeaveCall">🚫 ОБОРВАТЬ СВЯЗЬ</button>
            }
        </div>
    </div>
</div>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";
    private bool _inCall = false, _isCamOn = true;
    private DotNetObjectReference<Chat>? _objRef;

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hub.On<string, string>("ReceiveMessage", async (u, t) => {
            messages.Add(new Message { User = u, Text = t });
            await InvokeAsync(StateHasChanged);
            await JS.InvokeVoidAsync("scrollToEnd", "msgList");
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            if (string.IsNullOrEmpty(signal)) return;

            await InvokeAsync(async () => {
                if (signal == "requestList") {
                    if (_inCall) await SendOffer(senderId);
                }
                else if (signal.Contains("candidate")) 
                    await JS.InvokeVoidAsync("addIceCandidateGroup", signal, senderId);
                else if (signal.Contains("\"type\":\"offer\"")) {
                    var answer = await JS.InvokeAsync<string>("processOfferGroup", signal, senderId);
                    await SendSignalToHub(answer, senderId);
                }
                else if (signal.Contains("\"type\":\"answer\"")) 
                    await JS.InvokeVoidAsync("processAnswerGroup", signal, senderId);
            });
        });

        hub.On<string>("UserLeft", async id => {
            await JS.InvokeVoidAsync("removeUser", id);
        });

        hub.On<string>("UserJoined", async id => { 
            if (_inCall) await SendOffer(id); 
        });

        await hub.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("prepareWebRTC", _objRef);
        }
    }

    [JSInvokable]
    public async Task SendSignalJS(string signal, string targetId) => await SendSignalToHub(signal, targetId);

    private async Task SendSignalToHub(string signal, string targetId) {
        if (hub?.State == HubConnectionState.Connected) 
            await hub.SendAsync("SendSignal", signal, targetId);
    }

    private async Task SendOffer(string targetId) {
        var offer = await JS.InvokeAsync<string>("createOfferGroup", targetId);
        await SendSignalToHub(offer, targetId);
    }

    private async Task JoinCall() {
        var ok = await JS.InvokeAsync<bool>("startLocalVideo", "localVideo");
        if (ok) {
            _inCall = true;
            await SendSignalToHub("requestList", "all");
        }
    }

    private async Task LeaveCall() {
        _inCall = false;
        await JS.InvokeVoidAsync("hangup");
    }

    private async Task Send() {
        if (!string.IsNullOrWhiteSpace(newMessage) && hub?.State == HubConnectionState.Connected) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    
    private async Task ToggleCam() { 
        _isCamOn = !_isCamOn; 
        await JS.InvokeVoidAsync("toggleVideo", _isCamOn); 
    }

    public async ValueTask DisposeAsync() {
        _objRef?.Dispose();
        if (hub != null) await hub.DisposeAsync();
    }

    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
