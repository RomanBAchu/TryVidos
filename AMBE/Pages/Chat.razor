@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-container">
    <div class="messages-list">
        @foreach (var msg in messages) { 
            <div class="@(msg.User == "Система" ? "text-danger small" : "")">
                <b>@msg.User:</b> @msg.Text
            </div> 
        }
    </div>

    <div class="video-grid">
        <video id="localVideo" autoplay muted playsinline></video>
        <video id="remoteVideo" autoplay playsinline></video>
    </div>

    <div class="text-center p-2 d-flex justify-content-center gap-2">
        @if (!_videoActive) {
            <button class="btn btn-success rounded-pill" @onclick="StartCall">📞 Позвонить</button>
        } else {
            <button class="btn btn-danger rounded-pill" @onclick="EndCall">🚫 Сбросить</button>
        }
    </div>

    <div class="input-group">
        <input @bind="userName" class="form-control" placeholder="Имя" style="width:20%" />
        <input @bind="newMessage" @onkeyup="HandleKeyPress" class="form-control" placeholder="Сообщение..." style="width:60%" />
        <button class="btn btn-primary" @onclick="Send">OK</button>
    </div>
</div>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";
    private bool _videoActive = false;

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => {
            messages.Add(new Message { User = u, Text = t });
            InvokeAsync(StateHasChanged);
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            try {
                if (signal.Contains("candidate")) {
                    await JS.InvokeVoidAsync("addIceCandidate", signal);
                }
                else if (signal.Contains("offer")) {
                    if (!_videoActive) {
                        await JS.InvokeVoidAsync("startLocalVideo", "localVideo");
                        _videoActive = true;
                        StateHasChanged();
                        await Task.Delay(800); 
                    }
                    var answer = await JS.InvokeAsync<string>("processOffer", signal);
                    await hub.SendAsync("SendSignal", answer, senderId);
                }
                else if (signal.Contains("answer")) {
                    await JS.InvokeVoidAsync("processAnswer", signal);
                }
                else if (signal == "hangup") {
                    await EndCallInternal();
                }
            } catch (Exception ex) {
                Console.WriteLine("Signal Error: " + ex.Message);
                messages.Add(new Message { User = "Система", Text = "Ошибка сигнала: " + ex.Message });
                await InvokeAsync(StateHasChanged);
            }
        });

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task StartCall() {
        try {
            if (!_videoActive) {
                await JS.InvokeVoidAsync("startLocalVideo", "localVideo");
                _videoActive = true;
                StateHasChanged();
                await Task.Delay(1000); 
            }
            var offer = await JS.InvokeAsync<string>("createOffer");
            if (hub != null) await hub.SendAsync("SendSignal", offer, "all");
        } catch (Exception ex) {
            Console.WriteLine("StartCall Error: " + ex.Message);
            messages.Add(new Message { User = "Система", Text = "Ошибка связи: " + ex.Message });
            _videoActive = false;
        }
    }

    private async Task EndCall() {
        try {
            if (hub != null) await hub.SendAsync("SendSignal", "hangup", "all");
            await EndCallInternal();
        } catch (Exception ex) {
            Console.WriteLine("EndCall Error: " + ex.Message);
        }
    }

    private async Task EndCallInternal() {
        _videoActive = false;
        try {
            await JS.InvokeVoidAsync("hangup");
        } catch (Exception ex) {
            Console.WriteLine("JS Hangup Error: " + ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    [JSInvokable]
    public async Task SendIceCandidate(string candidate) {
        try {
            if (hub != null) await hub.SendAsync("SendSignal", candidate, "all");
        } catch (Exception ex) {
            Console.WriteLine("Candidate Error: " + ex.Message);
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    
    public async ValueTask DisposeAsync() { 
        if (hub != null) await hub.DisposeAsync(); 
    }

    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
