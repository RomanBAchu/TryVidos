@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-container spidey-theme">
    <div class="hud-header d-flex justify-content-between p-2">
        <span class="scan-line"></span>
        <div class="hud-title">FNSM // NETWORK_V2.3</div>
        <div class="hud-status">● ONLINE</div>
    </div>

    <div id="msgList" class="messages-list">
        @foreach (var msg in messages) { 
            <div class="msg-bubble @(msg.User == "Система" ? "sys-msg" : "")">
                <span class="msg-user">@msg.User.ToUpper()</span>
                <p class="msg-text">@msg.Text</p>
            </div> 
        }
    </div>

    <div class="video-section">
        <div class="video-controls d-flex align-items-center justify-content-center gap-3">
            <div class="local-v-container">
                <video id="localVideo" autoplay muted playsinline></video>
                <div class="video-label">YOU</div>
            </div>
            <div id="remoteVideos" class="d-flex flex-wrap justify-content-center gap-2"></div>
        </div>
    </div>

    <div class="action-bar text-center p-3">
        @if (!_inCall) {
            <button class="btn btn-spidey main-btn" @onclick="JoinCall">📞 ВОЙТИ В ЭФИР</button>
        } else {
            <button class="btn btn-hangup main-btn" @onclick="LeaveCall">🚫 ПРЕРВАТЬ СВЯЗЬ</button>
        }
    </div>

    <div class="input-area p-3">
        <div class="input-wrapper d-flex gap-2 mb-3">
            <input @bind="userName" class="spidey-input name-input" placeholder="ID" />
            <input @bind="newMessage" @onkeyup="HandleKeyPress" class="spidey-input msg-input" placeholder="Сообщение..." />
            <button class="btn-send" @onclick="Send">Отправить</button>
        </div>
    </div>
</div>

<style>
    :root {
        --spidey-red: #e62429;
        --spidey-blue: #0096FF;
        --neon-glow: 0 0 15px rgba(230, 36, 41, 0.6);
    }
    .spidey-theme { background: radial-gradient(circle at center, #1a1a2e 0%, #050505 100%); color: white; height: 100vh; display: flex; flex-direction: column; }
    .hud-header { background: rgba(230, 36, 41, 0.15); border-bottom: 1px solid var(--spidey-red); font-size: 0.7rem; }
    .messages-list { flex: 1; overflow-y: auto; padding: 20px; background: rgba(0,0,0,0.2); scroll-behavior: smooth; }
    .msg-bubble { background: rgba(255, 255, 255, 0.05); border-left: 4px solid var(--spidey-red); padding: 10px; margin-bottom: 10px; border-radius: 0 12px 12px 0; }
    .msg-user { color: var(--spidey-red); font-size: 0.7rem; font-weight: bold; }
    .video-section { background: rgba(0,0,0,0.5); padding: 10px; border-top: 1px solid var(--spidey-red); }
    #localVideo { width: 200px; height: 200px; border-radius: 50%; border: 2px solid var(--spidey-red); box-shadow: var(--neon-glow); object-fit: cover; }
    .remote-v { width: 110px; height: 110px; border-radius: 10px; border: 1px solid var(--spidey-blue); object-fit: cover; }
    .main-btn { padding: 15px 40px !important; border-radius: 30px !important; font-weight: 900; letter-spacing: 2px; }
    .btn-spidey { background: var(--spidey-red); border: none; color: white; box-shadow: var(--neon-glow); }
    .btn-hangup { background: #222; border: 2px solid var(--spidey-red); color: white; }
    .input-area { background: #000; padding-bottom: 40px !important; }
    .spidey-input { background: rgba(255,255,255,0.1); border: 1px solid var(--spidey-red); color: white; padding: 12px; border-radius: 10px; }
    .name-input { width: 90px; text-align: center; }
    .msg-input { flex: 1; padding: 22px;}
    .btn-send { background: var(--spidey-blue); border: none; color: white; padding: 8px 25px; border-radius: 10px; font-weight: bold; }
</style>

@code {
    private HubConnection? hub;
    private List<Message> messages = new();
    private string userName = "Чудило", newMessage = "";
    private bool _inCall = false;

    protected override async Task OnInitializedAsync() {
        hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/chathub")).WithAutomaticReconnect().Build();

        hub.On<string, string>("ReceiveMessage", (u, t) => InvokeAsync(async () => {
            messages.Add(new Message { User = u, Text = t });
            if (u != userName) await JS.InvokeVoidAsync("spideyVibrate", 100);
            StateHasChanged();
            await JS.InvokeVoidAsync("scrollToEnd", "msgList");
        }));

        hub.On<List<string>>("UserList", async (users) => {
            if (_inCall && hub != null) {
                foreach (var id in users) {
                    var offer = await JS.InvokeAsync<string?>("createOfferGroup", id);
                    if (offer != null) await hub.SendAsync("SendSignal", offer, id);
                }
            }
        });

        hub.On<string, string>("ReceiveSignal", async (signal, senderId) => {
            await InvokeAsync(async () => {
                if (hub == null) return;
                try {
                    if (signal == "requestList" && _inCall) {
                        var offer = await JS.InvokeAsync<string?>("createOfferGroup", senderId);
                        if (offer != null) await hub.SendAsync("SendSignal", offer, senderId);
                    }
                    else if (signal.Contains("candidate")) await JS.InvokeVoidAsync("addIceCandidateGroup", signal, senderId);
                    else if (signal.Contains("offer")) {
                        var answer = await JS.InvokeAsync<string?>("processOfferGroup", signal, senderId);
                        if (answer != null) await hub.SendAsync("SendSignal", answer, senderId);
                    }
                    else if (signal.Contains("answer")) await JS.InvokeVoidAsync("processAnswerGroup", signal, senderId);
                } catch { }
            });
        });

        hub.On<string>("UserLeft", id => JS.InvokeVoidAsync("removeUser", id));

        await hub.StartAsync();
        await JS.InvokeVoidAsync("prepareWebRTC", DotNetObjectReference.Create(this));
    }

    private async Task JoinCall() {
        var ok = await JS.InvokeAsync<bool>("startLocalVideo", "localVideo");
        if (ok && hub != null) {
            _inCall = true;
            await JS.InvokeVoidAsync("spideyVibrate", new int[] { 50, 30, 50 });
            await hub.SendAsync("SendMessage", "Система", userName + " зашел.");
            await hub.SendAsync("SendSignal", "requestList", "all");
        }
    }

    private async Task LeaveCall() {
        _inCall = false;
        await JS.InvokeVoidAsync("hangup");
        if (hub != null) await hub.SendAsync("SendMessage", "Система", userName + " вышел.");
    }

    private async Task Send() {
        if (hub != null && !string.IsNullOrWhiteSpace(newMessage)) {
            await hub.SendAsync("SendMessage", userName, newMessage);
            newMessage = "";
        }
    }

    [JSInvokable] public async Task SendSignalJS(string sig, string tid) {
        if (hub != null) await hub.SendAsync("SendSignal", sig, tid);
    }

    private async Task HandleKeyPress(KeyboardEventArgs e) { if (e.Key == "Enter") await Send(); }
    public async ValueTask DisposeAsync() { if (hub != null) await hub.DisposeAsync(); }
    public class Message { public string User { get; set; } = ""; public string Text { get; set; } = ""; }
}
